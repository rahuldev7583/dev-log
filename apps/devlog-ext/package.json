{
  "name": "devlog-extension",
  "displayName": "Devlog Extension",
  "publisher": "rahuldevkai75",
  "description": "",
  "version": "0.0.7",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
"activationEvents": [
  "onCommand:devlog-extension.login",
  "onCommand:devlog-extension.reset",
  "onCommand:devlog-extension.helloWorld",
  "onStartupFinished",
  "onUri"
],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Devlog",
      "properties": {
        "devlogTracker.apiUrl": {
          "type": "string",
          "default": "https://api.thelogger.dev",
          "description": "Backend API URL"
        },
        "devlogTracker.appUrl": {
          "type": "string",
          "default": "https://thelogger.dev",
          "description": "Frontend APP URL"
        }
      }
    },
    "commands": [
        {
        "command": "devlog-extension.login",
        "title": "Devlog: Login"
    },
    {
        "command": "devlog-extension.reset",
        "title": "Devlog: Reset"
    },
    {
        "command": "devlog-extension.sync",
        "title": "Devlog: Sync Now"
    }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "build": "node build.js"
    
  },
  "dependencies": {
    "axios": "^1.13.6",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@types/node": "~22.15.3",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
